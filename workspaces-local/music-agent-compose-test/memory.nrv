
on external "remember_music"
  meta = { category: "music" }
  if event.payload
    meta = event.payload
  end
  stored = tool("memory_store", {
    text: event.value,
    metadata: meta
  })
  if state.storeCount > 0
    state.storeCount = state.storeCount + 1
  else
    state.storeCount = 1
  end
  state.lastStored = stored
  output json {
    status: "stored",
    totalStored: state.storeCount,
    stored: stored,
  }
end

on external "recall_music"
  filter = {}
  recall_limit = 10
  if event.payload & event.payload.filter
    filter = event.payload.filter
  end
  if event.payload & event.payload.limit
    recall_limit = event.payload.limit
  end
  results = tool("memory_retrieve", {
    query_text: event.value,
    limit: recall_limit,
    filter_metadata: filter
  })
  state.lastQuery = event.value
  state.lastResults = results.items
  output json {
    status: "results",
    query: state.lastQuery,
    count: results.count,
    items: results.items,
  }
end

on external "delete_music"
  deleted = tool("memory_delete", {
    id: event.value
  })
  if deleted.deleted & state.storeCount > 0
    state.storeCount = state.storeCount - 1
  end
  # state.lastDeleted = deleted
  output json {
    status: "deleted",
    deleted: deleted.deleted,
    id: deleted.id,
  }
end

on external "update_music"
  meta = { category: "music" }
  if event.payload & event.payload.metadata
    meta = event.payload.metadata
  end
  updated = tool("memory_update", {
    id: event.value,
    text: event.payload.text,
    metadata: meta
  })
  # state.lastUpdated = updated
  output json {
    status: "updated",
    updated: updated.updated,
    id: updated.id,
  }
end