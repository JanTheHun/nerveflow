on "summarize_urgent"
  urgent_snapshot = tool("query_articles", { unread: true, priority: "urgent", limit: 50 })
  urgent_count = urgent_snapshot.count
  output json urgent_snapshot.titles
  output voice to_json(urgent_snapshot.titles)
end

on "summarize_high"
  high_snapshot = tool("query_articles", { unread: true, priority: "high", limit: 50 })
  high_count = high_snapshot.count

  if high_count == 0
    emit("user_output", "No high-priority articles at the moment.")
  else
    emit("user_output", concat(high_count, " high-priority article(s):"))
    emit("user_output", high_snapshot.titles)
  end
end

on "summarize_normal"
  normal_snapshot = tool("query_articles", { unread: true, priority: "normal", limit: 50 })
  normal_count = normal_snapshot.count

  if normal_count == 0
    emit("user_output", "No normal-priority articles at the moment.")
  else
    emit("user_output", concat(normal_count, " normal-priority article(s):"))
    emit("user_output", normal_snapshot.titles)
  end
end

on "summarize_unread_priorities"
  if length(state.unreadArticles) > 0
    unread_articles = state.unreadArticles
  else
    unread_snapshot = tool("query_articles", { unread: true, limit: 200 })
    unread_articles = unread_snapshot.articles
  end

  total_count = length(unread_articles)
  urgent_count = total_count - length(remove_by(unread_articles, "priority", "urgent"))
  high_count = total_count - length(remove_by(unread_articles, "priority", "high"))
  normal_count = total_count - length(remove_by(unread_articles, "priority", "normal"))
  pending_count = total_count - length(remove_by(unread_articles, "priority", "pending"))
  ignore_count = total_count - length(remove_by(unread_articles, "priority", "ignore"))

  priority_summary = {
    total: total_count,
    urgent: urgent_count,
    high: high_count,
    normal: normal_count,
    pending: pending_count,
    ignore: ignore_count
  }

  emit("user_output", concat(
    "Unread by priority (",
    total_count,
    " total): ",
    urgent_count,
    " urgent, ",
    high_count,
    " high, ",
    normal_count,
    " normal, ",
    pending_count,
    " pending, ",
    ignore_count,
    " ignore"
  ))
  emit("user_output", priority_summary)
end
