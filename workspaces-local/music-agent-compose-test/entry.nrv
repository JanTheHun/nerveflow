include "intent_unknown.nrv"
include "memory.nrv"
include "music-select.nrv"
include "user-wants-music.nrv"

on external "user_message"
  # Classify user intent in parallel using both intent models
  instructions = file("entry-instructions.md")
  intent_contract = {
    intent: ["play", "unclear"]
  }
  
  # result = agent(
    # "intent-2",
    # event.value,
    # instructions,
    # format="json"
  # )

  # output json result

  # result2 = agent(
    # "intent",
    # event.value,
    # instructions,
    # format="json"
  # )

  # output json result2


  intent_results = parallel([
    agent(
      "groq",
      event.value,
      instructions,
      returns=intent_contract
    ),
    agent(
      "gemini",
      event.value,
      instructions,
      returns=intent_contract
    )
  ])
  
  output json intent_results
  
  emit("user_wants_music", event.value)
end

on "violation"
  output json event.value
end