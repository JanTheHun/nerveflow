{
  "name": "nerveflow",
  "version": "0.1.4",
  "description": "Deterministic control layer for AI workflows",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "nerve-runtime": "./bin/nerve-runtime.js",
    "nerve-attach": "./bin/nerve-attach.js",
    "nerve-dev-remote": "./bin/nerve-dev-remote.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./host_core": "./src/host_core/index.js",
    "./host_core/protocol": "./src/host_core/protocol.js",
    "./runtime": "./src/runtime/index.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "dev:remote": "node bin/nerve-dev-remote.js"
  },
  "devDependencies": {
    "aedes": "^1.0.2",
    "mqtt": "^5.15.1",
    "ws": "^8.18.3"
  },
  "homepage": "https://github.com/janthehun/nerveflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/janthehun/nerveflow.git"
  },
  "keywords": [
    "nextv",
    "nerveflow",
    "workflow",
    "deterministic",
    "event-driven",
    "state-machine",
    "runtime"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "bin/nerve-runtime.js",
    "bin/nerve-attach.js",
    "bin/nerve-dev-remote.js",
    "docs/",
    "examples/minimal-web-host/server.js",
    "examples/minimal-web-host/README.md",
    "examples/minimal-web-host/workflow.nrv",
    "examples/minimal-web-host/package.json",
    "examples/minimal-web-host/public/index.html",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    ".npmignore"
  ]
}
