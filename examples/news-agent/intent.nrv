on external "user_message"
  route = agent(
    "priority",
    concat(
      "Current favorite topics: ",
      to_json(state.favoriteTopics),
      "\\n\\nUser message: ",
      event.value
    ),
    file("prompts\intent.md"),
    returns={ intent: ["news", "urgent", "high", "normal", "poll", "reset", "set_topics", "add_topics", "remove_topics", "other"], topics: { markets: false, geopolitics: false, ai: false, energy: false, other: false } },
    retry_on_contract_violation=1,
    on_contract_violation=emit("user_output", concat("[intent-contract] field=", violation.field, " expected=", violation.expected, " actual=", violation.actual))
  )

  output json route
  emit("user_output", concat("[intent] ", route.intent))

  if route.intent == "news"
    emit("summarize_unread_priorities", event.value)
  else if route.intent == "urgent"
    emit("summarize_urgent", event.value)
  else if route.intent == "high"
    emit("summarize_high", event.value)
  else if route.intent == "normal"
    emit("summarize_normal", event.value)
  else if route.intent == "poll"
    state.refreshIngestedCount = 0
    state.refreshBatchCount = 0
    emit("ingest_poll_batch", "poll")
  else if route.intent == "reset"
    emit("reset_unread_articles", event.value)
  else if route.intent == "set_topics"
    emit("set_topics", route.topics)
  else if route.intent == "add_topics"
    emit("add_topics", route.topics)
  else if route.intent == "remove_topics"
    emit("remove_topics", route.topics)
  else
    output voice "didn't get that, sorry"
    emit("user_output", "I can summarize unread news by priority (urgent, high, normal), fetch new articles, reset the unread list, or set/add/remove your topic preferences.")
  end
end
