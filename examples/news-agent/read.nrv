on external "mark_read"
  result = tool("mark_read", { articleId: event.value })
  unread_snapshot = tool("query_articles", { unread: true, limit: 200 })
  deduped_unread = dedupe_by(unread_snapshot.articles, "id")
  state.unreadArticles = deduped_unread
  state.unreadCount = length(deduped_unread)
  emit("user_output", concat("Marked read: ", to_json(result)))
end

on "reset_unread_articles"
  result = tool("reset_unread_articles", {})
  state.unreadArticles = []
  state.unreadCount = 0
  emit("user_output", concat("Cleared unread articles: ", to_json(result)))
end
