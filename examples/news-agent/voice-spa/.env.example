# voice-spa server binding
PORT=4318

# runtime endpoints
RUNTIME_INGRESS_URL=http://127.0.0.1:4173/api/nextv/ingress
RUNTIME_SSE_URL=http://127.0.0.1:4173/api/nextv/stream
# Optional. If unset, the server infers ws URL from ingress/sse URL.
# RUNTIME_WS_URL=ws://127.0.0.1:4173/api/nextv/ws

# workflow ingress and output channel
VOICE_INGRESS_NAME=user_message
VOICE_OUTPUT_CHANNEL=json

# transport policy: ws-only | ws-fallback | http-only
VOICE_TRANSPORT_MODE=ws-fallback

# request limits
VOICE_MAX_AUDIO_BYTES=10485760
VOICE_RATE_LIMIT_WINDOW_MS=60000
VOICE_RATE_LIMIT_MAX_REQUESTS=12

# whisper
WHISPER_RUN_PATH=./mock/bin/whisper-runner
# Example placeholders: {input} {output} {model}
WHISPER_RUN_ARGS=--input "{input}" --output-json "{output}.json"
WHISPER_MODEL=./mock/models/whisper/base.en.bin

# piper
PIPER_RUN_PATH=./mock/bin/piper
# Example placeholders: {output} {model}
PIPER_RUN_ARGS=--model "{model}" --output_file "{output}"
PIPER_MODEL=./mock/models/piper/en_US-lessac-medium.onnx
