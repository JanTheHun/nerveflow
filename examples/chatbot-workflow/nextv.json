{
  "entrypointPath": "entry.nrv",
  "externals": ["user_message", "reset_chat"],
  "effects": {
    "switch": {
      "kind": "gpio",
      "format": "json"
    }
  },
  "models": {
    "chat-model": {
      "model": "cogito:3b",
      "transport": "ollama"
    },
    "intent-model": {
      "model": "phi3:mini-128k",
      "transport": "ollama"
    }
  },
  "agents": {
    "profiles": {
      "chat": {
        "model": "chat-model",
        "tools": [],
        "instructions": "You are a concise, helpful chatbot. Use the conversation history and respond naturally to the latest user message."
      },
      "intent": {
        "model": "intent-model",
        "tools": []
      }
    }
  }
}
