{
  "entrypointPath": "entry.nrv",
  "externals": [
    "user_message",
    "tool_call_smoke",
    "remember_music",
    "recall_music",
    "delete_music",
    "update_music"
  ],
  "effects": {
    "play_music": {
      "format": "json"
    }
  },
  "transports": {
    "ollama": {
      "provider": "ollama",
      "keep_alive": "30m"
    },
    "groq": {
      "provider": "openai_compat",
      "baseUrl": "https://api.groq.com/openai",
      "apiKey": "${env:GROQ_API_KEY}"
    },
    "gemini": {
      "provider": "openai_compat",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
      "apiKey": "${env:GEMINI_API_KEY}"
    }
  },
  "models": {
    "chat-model": {
      "model": "llama3.2:1b",
      "transport": "ollama"
    },
    "smoke-chat-model": {
      "model": "gpt-oss:20b",
      "transport": "ollama"
    },
    "intent-model": {
      "model": "qwen3.5:0.8b",
      "transport": "ollama"
    },
    "intent-2-model": {
      "model": "llama3.2:1b",
      "transport": "ollama"
    },
    "intent-3-model": {
      "model": "phi3:mini-128k",
      "transport": "ollama"
    },
    "intent-4-model": {
      "model": "phi3:mini-4k",
      "transport": "ollama"
    },
    "intent-5-model": {
      "model": "gemma2:2b",
      "transport": "ollama"
    },
    "groq-model": {
      "model": "openai/gpt-oss-20b",
      "transport": "groq"
    },
    "gemini-model": {
      "model": "gemini-2.5-flash-lite",
      "transport": "gemini"
    }
  },
  "tools": {
    "allow": ["get_time", "memory_retrieve", "memory_store", "memory_delete", "memory_update"]
  },
  "requires": {
    "memory": {
      "required": true,
      "provider": "memory"
    }
  },
  "modules": {
    "memory": {
      "provider": "memory-pgvector",
      "mode": "embedded"
    }
  }
}
