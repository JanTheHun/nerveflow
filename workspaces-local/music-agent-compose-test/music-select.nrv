on "user_wants_music"

  filter = { category: "music" }
  if event.payload
    filter = event.payload
  end

  results = tool("memory_retrieve", {
    query_text: event.value,
    limit: 10,
    filter_metadata: filter
  })

  limit = 0.6

  relevant = cut(results.items, "similarity", ">=", limit)

	# output json relevant

	context = { query: event.value, candidates: relevant }
	  music = agent(
	    "chat",
	    to_json(context),
	    to_json(file("music-select/music-3.instructions.md")),
			returns={candidates:[{id: "", type: "", relevance: 0}]}
    )

		output json music

end